# HotPlex Worker Gateway - Environment Variables Example
#
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED SECRETS (MUST be set)
# ─────────────────────────────────────────────────────────────────────────────

# JWT secret for session token validation (ES256 or HS256)
# Generate: openssl rand -base64 32 | tr -d '\n'
HOTPLEX_JWT_SECRET=

# Admin API access tokens (Numbered suffix _1..N for secret rotation)
# Format: Any secure string. Comma-separated or numbered suffixes supported.
# Generate: openssl rand -base64 32 | tr -d '/+=' | head -c 43
HOTPLEX_ADMIN_TOKEN_1=
HOTPLEX_ADMIN_TOKEN_2=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL CLIENT AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────

# API keys for high-level client authentication (Numbered suffix _1..N supported)
# HOTPLEX_SECURITY_API_KEY_1=key1
# HOTPLEX_SECURITY_API_KEY_2=key2

# ─────────────────────────────────────────────────────────────────────────────
# CORE CONFIGURATION OVERRIDES
# ─────────────────────────────────────────────────────────────────────────────

# Log level: debug, info, warn, error (default: info)
# HOTPLEX_LOG_LEVEL=info

# Log format: json (production), text (development)
# HOTPLEX_LOG_FORMAT=text

# Database path (default: data/hotplex-worker.db)
# HOTPLEX_DB_PATH=data/prod.db

# Gateway & Admin addresses
# HOTPLEX_GATEWAY_ADDR=:8888
# HOTPLEX_ADMIN_ADDR=:9999

# ─────────────────────────────────────────────────────────────────────────────
# RESOURCE LIMITS & POOLING
# ─────────────────────────────────────────────────────────────────────────────

# Maximum concurrent sessions globally
# HOTPLEX_SESSION_MAX_CONCURRENT=1000

# session pool maximum size
# HOTPLEX_POOL_MAX_SIZE=100

# Max memory per user (in bytes, e.g., 2GB = 2147483648)
# HOTPLEX_POOL_MAX_MEMORY_PER_USER=2147483648

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY (OPTIONAL)
# ─────────────────────────────────────────────────────────────────────────────

# OpenTelemetry exporter endpoint (e.g., http://otel-collector:4318)
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Service name for traces/metrics
# OTEL_SERVICE_NAME=hotplex-worker-gateway

# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT ONLY (DO NOT USE IN PRODUCTION)
# ─────────────────────────────────────────────────────────────────────────────

# Disable TLS (WSS) - Default is false
# HOTPLEX_SECURITY_TLS_ENABLED=false

# Allow all CORS origins - Default is *
# HOTPLEX_SECURITY_ALLOWED_ORIGINS=*
