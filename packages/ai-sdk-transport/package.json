{
  "name": "@hotplex/ai-sdk-transport",
  "version": "0.1.0",
  "description": "AI SDK ChatTransport adapter for HotPlex Worker Gateway (AEP v1 over WebSocket)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1"
  },
  "peerDependencies": {
    "ai": ">=4.0.0",
    "react": ">=18.0.0",
    "@ai-sdk/react": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@ai-sdk/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "ai": "^4.3.19",
    "@ai-sdk/react": "^4.0.0-beta.62",
    "react": "^19.0.0",
    "@types/react": "^18.3.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "hotplex",
    "ai-sdk",
    "chat-transport",
    "websocket",
    "aep"
  ],
  "license": "Apache-2.0"
}
