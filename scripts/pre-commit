#!/bin/bash
# Git pre-commit hook for HotPlex
# Fast checks to ensure code health before commit

set -e

# ANSI color codes
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

printf "${YELLOW}🔍 Running pre-commit checks...${NC}\n"

# 1. Format Check (go fmt)
printf "🔹 Checking code formatting (go fmt)...\n"
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep ".go$" || true)
if [ -n "$STAGED_GO_FILES" ]; then
    DIFF=$(gofmt -d $STAGED_GO_FILES)
    if [ -n "$DIFF" ]; then
        printf "${YELLOW}⚠️  Staged code is not formatted correctly. Please run 'go fmt' on these files:${NC}\n"
        echo "$STAGED_GO_FILES"
        exit 1
    fi
fi

# 2. Dependency Check (go mod tidy)
if git diff --cached --name-only | grep -E "go.mod|go.sum" > /dev/null; then
    printf "🔹 Verifying dependencies (go mod tidy)...\n"
    go mod tidy
    if ! git diff --exit-code go.mod go.sum > /dev/null; then
        printf "${YELLOW}⚠️  go.mod or go.sum are out of sync. Please run 'go mod tidy' and stage the changes.${NC}\n"
        exit 1
    fi
fi

# 3. Check for forbidden placeholders/debug code
printf "🔹 Scanning for 'TODO' or debug markers in staged files...\n"
# Just an example, can be customized
FORBIDDEN_PATTERNS=("fmt\.Printf" "panic(" "DEBUG_ONLY")
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep ".go$" || true)

if [ -n "$STAGED_FILES" ]; then
    for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
        if grep -n "$pattern" $STAGED_FILES &> /dev/null; then
            printf "${YELLOW}⚠️  Found forbidden pattern '$pattern' in staged code. Please review.${NC}\n"
            # exit 1 # Uncomment to make it blocking
        fi
    done
fi

printf "${GREEN}✅ Pre-commit checks passed!${NC}\n"
exit 0
