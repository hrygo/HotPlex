#!/bin/bash
# Git pre-push hook for HotPlex
# Final guard before code leaves the local machine

set -e

# ANSI color codes
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

printf "${YELLOW}🚀 Running final pre-push validation...${NC}\n"

# 1. Build validation (Ensures the main binary is at least buildable)
printf "🔹 Verifying build (cmd/hotplexd)...\n"
if ! go build -o /dev/null ./cmd/hotplexd/main.go; then
    printf "${RED}❌ Build failed! Please fix compilation errors before pushing.${NC}\n"
    exit 1
fi

# 2. Run golangci-lint
if command -v golangci-lint &> /dev/null; then
    printf "🔹 Running linter (golangci-lint)...\n"
    golangci-lint run ./...
else
    printf "${YELLOW}⚠️  golangci-lint not found, skipping linting.${NC}\n"
fi

# 3. Run Go tests (Fast Unit Tests)
printf "🔹 Running fast unit tests...\n"
if ! make test-unit; then
    printf "${RED}❌ Unit tests failed! Push aborted.${NC}\n"
    exit 1
fi

printf "${GREEN}✅ All quality gates passed! Push authorized.${NC}\n"
exit 0
