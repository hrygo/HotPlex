# HotPlex Minimal Configuration
# Copy to .env and fill in your values

# Core
HOTPLEX_PORT=8080
HOTPLEX_API_KEY=your-api-key-here

# Provider
HOTPLEX_PROVIDER_TYPE=claude-code
HOTPLEX_PROVIDER_MODEL=sonnet
HOTPLEX_LOG_LEVEL=INFO

# Projects
HOTPLEX_PROJECTS_DIR=~/projects
HOTPLEX_GITCONFIG=~/.gitconfig

# Slack
HOTPLEX_SLACK_BOT_USER_ID=UXXXXXXXXXX
HOTPLEX_SLACK_MODE=socket
HOTPLEX_SLACK_BOT_TOKEN=xoxb-your-bot-token
HOTPLEX_SLACK_APP_TOKEN=xapp-your-app-token
HOTPLEX_SLACK_SIGNING_SECRET=
