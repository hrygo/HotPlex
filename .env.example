# ==============================================================================
# 🚀 HotPlex 环境配置模版
# ==============================================================================
# 使用说明：
# 1. 复制此文件为 '.env'：cp .env.example .env
# 2. 根据你的实际凭据更新下方变量。
# 3. 出于安全考虑，切勿将你的 '.env' 文件提交到版本控制系统。
#
# 📋 配置规则：
# - 敏感凭据（Token/Secret/Key）→ 本文件
# - 行为配置（Timeout/Policy/Mode）→ YAML 配置文件（chatapps/configs/*.yaml）
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 🌐 核心服务器 (Core Server) - 仅敏感凭据
# ------------------------------------------------------------------------------

# API 安全令牌（生产环境必选）
# 生成建议：openssl rand -hex 32
HOTPLEX_API_KEY=在此处生成强令牌

# ------------------------------------------------------------------------------
# 2. 🤖 AI 提供商 (Provider) - 仅敏感凭据
# ------------------------------------------------------------------------------

# GitHub PAT（用于 Git 操作）
GITHUB_TOKEN=ghp_在此处填写你的GitHub令牌

# ------------------------------------------------------------------------------
# 3. 💬 聊天机器人适配器 (Bot Adapters) - 仅敏感凭据
# ------------------------------------------------------------------------------

# --- Slack App ---
# 申请地址：https://api.slack.com/apps
HOTPLEX_SLACK_BOT_USER_ID=UXXXXXXXXXX        # Bot 标识（非敏感，但 Bot 特定）
HOTPLEX_SLACK_BOT_TOKEN=xoxb-在此填入        # 敏感
HOTPLEX_SLACK_APP_TOKEN=xapp-在此填入        # 敏感
HOTPLEX_SLACK_SIGNING_SECRET=在此填入        # 敏感

# --- Telegram Bot ---
HOTPLEX_TELEGRAM_BOT_TOKEN=
HOTPLEX_TELEGRAM_SECRET_TOKEN=

# --- Discord Bot ---
HOTPLEX_DISCORD_BOT_TOKEN=
HOTPLEX_DISCORD_PUBLIC_KEY=

# --- 钉钉 (DingTalk) ---
HOTPLEX_DINGTALK_APP_ID=
HOTPLEX_DINGTALK_APP_SECRET=

# --- WhatsApp (Meta Cloud API) ---
HOTPLEX_WHATSAPP_PHONE_NUMBER_ID=
HOTPLEX_WHATSAPP_ACCESS_TOKEN=

# --- Feishu (飞书) ---
HOTPLEX_FEISHU_APP_ID=
HOTPLEX_FEISHU_APP_SECRET=

# ------------------------------------------------------------------------------
# 4. 🧠 原生大脑 (Brain) - 仅敏感凭据
# ------------------------------------------------------------------------------

# Brain API 密钥
HOTPLEX_BRAIN_API_KEY=

# ------------------------------------------------------------------------------
# 5. 🛡️ 告警 (Alerts) - 仅敏感凭据
# ------------------------------------------------------------------------------

# 钉钉告警 Webhook
HOTPLEX_DINGTALK_WEBHOOK_URL=
HOTPLEX_DINGTALK_SECRET=

# ==============================================================================
# 📝 非敏感配置请修改 YAML 文件：
# - chatapps/configs/slack.yaml    - Slack 行为配置
# - chatapps/configs/telegram.yaml - Telegram 行为配置
# - chatapps/configs/feishu.yaml   - 飞书行为配置
# ...
# ==============================================================================


