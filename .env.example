# ==============================================================================
# 🚀 HotPlex 环境配置模版
# ==============================================================================
# 使用说明：
# 1. 复制此文件为 '.env'：cp .env.example .env
# 2. 根据你的实际凭据更新下方变量。
# 3. 出于安全考虑，切勿将你的 '.env' 文件提交到版本控制系统。
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 🌐 核心服务器设置
# ------------------------------------------------------------------------------

# HotPlex 代理服务器监听的端口
HOTPLEX_PORT=8080

# API 安全与认证（生产环境必填）
# 此令牌用于控制对 HotPlex 控制面板（WebSocket 和 HTTP API）的访问。
# 使用方法：
#   - 请求头：   X-API-Key: <你的令牌>
#   - 查询参数： ?api_key=<你的令牌>
# 生成方法：在终端运行 'openssl rand -hex 32' 生成强随机令牌。
# 支持多个密钥（逗号分隔）：HOTPLEX_API_KEYS=key1,key2
HOTPLEX_API_KEY=在此处生成强令牌

# ------------------------------------------------------------------------------
# 2. 🤖 AI 提供商与引擎配置
# ------------------------------------------------------------------------------

# 后端 AI 提供商类型：[claude-code | opencode]
HOTPLEX_PROVIDER_TYPE=claude-code

# CLI 二进制路径（可选，为空则在系统 $PATH 中查找 'claude' 或 'opencode'）
HOTPLEX_PROVIDER_BINARY=

# 模型别名（可选：例如 sonnet, opus 或具体的版本字符串）
HOTPLEX_PROVIDER_MODEL=sonnet

# OpenCode 兼容层（默认：true）
# 启用旧版 /session 和 /global 路由以实现无缝迁移。
HOTPLEX_OPENCODE_COMPAT_ENABLED=true

# --- 🧠 原生大脑 (平台智能) ---
# 处理意图路由、安全防护和长期记忆压缩等编排工作。
# 提供商类型：openai（默认，支持任何 OpenAI 兼容的 API，如 DeepSeek, Groq 等）
HOTPLEX_BRAIN_PROVIDER=openai

# 原生大脑 API 密钥（使用大脑功能必填）
HOTPLEX_BRAIN_API_KEY=

# 用于快速内部推理的模型（默认：gpt-4o-mini）
HOTPLEX_BRAIN_MODEL=gpt-4o-mini

# 自定义 API 端点（可选，用于 DeepSeek/vLLM/本地 LLM）
# 例如：https://api.deepseek.com/v1
HOTPLEX_BRAIN_ENDPOINT=

# ------------------------------------------------------------------------------
# 3. ⚡ 性能、安全与日志
# ------------------------------------------------------------------------------

# 执行超时（AI 进程每轮运行的最大时间，默认：30m）
HOTPLEX_EXECUTION_TIMEOUT=30m

# 会话空闲超时（无活动后自动关闭后端 CLI 进程，默认：30m）
HOTPLEX_IDLE_TIMEOUT=30m

# 日志级别：DEBUG, INFO, WARN, ERROR
HOTPLEX_LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# 4. 📁 工作空间与身份（用于容器化 Bot）
# ------------------------------------------------------------------------------

# 工作目录：可以指定任意本地目录作为 Bot 访问的工作空间
# 映射到容器路径：/home/hotplex/projects
HOTPLEX_PROJECTS_DIR=${HOME}/.slack/BOT_USER_ID

# Git 配置：映射本地 Git 配置到容器中，方便 Bot 使用 Git 身份
# 映射到容器路径：/home/hotplex/.gitconfig
HOTPLEX_GITCONFIG=${HOME}/.gitconfig-bot

# GitHub 个人访问令牌 (PAT)
# 用于容器内 Bot 进行代码推送、提交 PR 等操作，可实现与宿主机不同的身份。
# 获取地址：https://github.com/settings/tokens (classic) -> 勾选 'repo' 权限。
GITHUB_TOKEN=ghp_此处填写你的令牌

# ------------------------------------------------------------------------------
# 5. 💬 聊天机器人适配器 (Bot Adapters)
# ------------------------------------------------------------------------------

# 是否全局启用聊天机器人层
HOTPLEX_CHATAPPS_ENABLED=true

# --- Slack 应用 ---
# 令牌获取地址：https://api.slack.com/apps
# 所需权限：app_mentions:read, chat:write, files:write 等。
HOTPLEX_SLACK_MODE=socket
HOTPLEX_SLACK_BOT_TOKEN=
HOTPLEX_SLACK_APP_TOKEN=
HOTPLEX_SLACK_SIGNING_SECRET=
HOTPLEX_SLACK_BOT_USER_ID=
HOTPLEX_SLACK_BOT_NAME=

# --- Telegram 机器人 ---
HOTPLEX_TELEGRAM_BOT_TOKEN=
HOTPLEX_TELEGRAM_WEBHOOK_URL=
HOTPLEX_TELEGRAM_SECRET_TOKEN=

# --- Discord 机器人 ---
HOTPLEX_DISCORD_BOT_TOKEN=
HOTPLEX_DISCORD_PUBLIC_KEY=

# --- 钉钉机器人 ---
HOTPLEX_DINGTALK_APP_ID=
HOTPLEX_DINGTALK_APP_SECRET=
HOTPLEX_DINGTALK_CALLBACK_TOKEN=
HOTPLEX_DINGTALK_CALLBACK_KEY=

# --- WhatsApp (Meta) ---
HOTPLEX_WHATSAPP_PHONE_NUMBER_ID=
HOTPLEX_WHATSAPP_ACCESS_TOKEN=
HOTPLEX_WHATSAPP_VERIFY_TOKEN=

# ------------------------------------------------------------------------------
# 6. 🛠 高级设置与可观测性
# ------------------------------------------------------------------------------

# CORS：允许访问的浏览器客户端来源（逗号分隔）
HOTPLEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# 钉钉安全告警（用于发送系统拦截和关键错误通知）
HOTPLEX_DINGTALK_ENABLED=false
HOTPLEX_DINGTALK_WEBHOOK_URL=
HOTPLEX_DINGTALK_SECRET=
HOTPLEX_DINGTALK_FILTER_EVENTS=danger.blocked,session.error

# ------------------------------------------------------------------------------
# 7. ⚙️ 路径与配置目录
# ------------------------------------------------------------------------------
# 配置文件查找优先级：1. HOTPLEX_CHATAPPS_CONFIG_DIR | 2. ~/.hotplex/configs | 3. ./chatapps/configs

# 用户配置根目录（默认：~/.hotplex）
# HOTPLEX_CONFIG_DIR=/path/to/hotplex

# 聊天机器人配置文件目录（默认：{HOTPLEX_CONFIG_DIR}/configs）
# HOTPLEX_CHATAPPS_CONFIG_DIR=/path/to/configs

# ------------------------------------------------------------------------------
# 8. 🔐 GITHUB TOKEN (For container bot)
# ------------------------------------------------------------------------------
# Allows container to use a different GitHub account than the host.
# Generate from: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=
