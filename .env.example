# ==============================================================================
# 🚀 HotPlex 环境配置模版
# ==============================================================================
# 使用说明：
# 1. 复制此文件为 '.env'：cp .env.example .env
# 2. 根据你的实际凭据更新下方变量。
# 3. 出于安全考虑，切勿将你的 '.env' 文件提交到版本控制系统。
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 🌐 核心服务器设置 (Core Server)
# ------------------------------------------------------------------------------

# HotPlex 代理服务器监听的端口
# 默认值：8080
HOTPLEX_PORT=8080

# API 安全与认证（生产环境必选）
# 此令牌用于控制对 HotPlex 控制面板、WebSocket 和 HTTP API 的访问权限。
# 使用方法：
#   - HTTP Header:  X-API-Key: <你的令牌>
#   - URL Query:    ?api_key=<你的令牌>
# 生成建议：在终端运行 'openssl rand -hex 32' 生成强随机字符串。
# 支持多密钥：可以使用逗号分隔，如 HOTPLEX_API_KEYS=key1,key2
HOTPLEX_API_KEY=在此处生成强令牌

# 允许跨域 (CORS) 的来源（逗号分隔）
# 示例：http://localhost:3000,http://app.hotplex.ai
HOTPLEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ------------------------------------------------------------------------------
# 2. 🤖 下游 AI 提供商驱动 (Downstream Providers)
# ------------------------------------------------------------------------------

# 后端执行引擎类型：[claude-code | opencode]
# claude-code: 使用 Anthropic 官方的 Claude Code CLI。
# opencode:    使用开源的 OpenCode CLI 实现。
HOTPLEX_PROVIDER_TYPE=claude-code

# CLI 二进制路径（可选）
# 为空时，HotPlex 会在系统 $PATH 中查找 'claude' 或 'opencode'。
# 如果你使用了特定的安装路径，请在此指定。
HOTPLEX_PROVIDER_BINARY=

# 引擎使用的模型别名（可选）
# 例如：sonnet, opus, 或具体的版本号（如 claude-3-5-sonnet-20241022）。
HOTPLEX_PROVIDER_MODEL=sonnet

# OpenCode 兼容层（默认：true）
# 启用旧版 /session 和 /global 路由，确保从旧版本无缝迁移。
HOTPLEX_OPENCODE_COMPAT_ENABLED=true

# ------------------------------------------------------------------------------
# 3. 💬 聊天机器人适配器 (Bot Adapters)
# ------------------------------------------------------------------------------

# 是否全局启用聊天机器人层（设为 false 则仅运行代理 API）
HOTPLEX_CHATAPPS_ENABLED=true

# --- Slack App 配置 ---
# 申请地址：https://api.slack.com/apps
# 模式：socket (推荐) 或 http
HOTPLEX_SLACK_MODE=socket
HOTPLEX_SLACK_BOT_TOKEN=xoxb-在此填入
HOTPLEX_SLACK_APP_TOKEN=xapp-在此填入
HOTPLEX_SLACK_SIGNING_SECRET=在此填入
# Bot User ID (用于 @ 提及检测) - 非敏感，也可在 YAML 中配置
HOTPLEX_SLACK_BOT_USER_ID=

# --- Telegram Bot ---
# 通过 @BotFather 获取
HOTPLEX_TELEGRAM_BOT_TOKEN=
# (Webhook 模式可选)
HOTPLEX_TELEGRAM_WEBHOOK_URL=
HOTPLEX_TELEGRAM_SECRET_TOKEN=

# --- Discord Bot ---
HOTPLEX_DISCORD_BOT_TOKEN=
HOTPLEX_DISCORD_PUBLIC_KEY=

# --- 钉钉 (DingTalk) ---
HOTPLEX_DINGTALK_APP_ID=
HOTPLEX_DINGTALK_APP_SECRET=

# --- WhatsApp (Meta Cloud API) ---
HOTPLEX_WHATSAPP_PHONE_NUMBER_ID=
HOTPLEX_WHATSAPP_ACCESS_TOKEN=

# ------------------------------------------------------------------------------
# 4. 🧠 原生大脑 (Global Brain - 核心编排引擎)
# ------------------------------------------------------------------------------
# “原生大脑”负责任务路由、安全防护、长期记忆压缩及工具调用的决策。
# 它通常使用一个轻量且快速的模型（如 GPT-4o-mini 或 DeepSeek-Chat）。

# 提供商类型：openai (支持所有 OpenAI 兼容协议的 API)
HOTPLEX_BRAIN_PROVIDER=openai

# 原生大脑 API 密钥（必填，否则大脑功能将失效）
HOTPLEX_BRAIN_API_KEY=

# 用于快速推理的模型名称
# 默认：gpt-4o-mini
HOTPLEX_BRAIN_MODEL=gpt-4o-mini

# 自定义 API 端点（可选，用于非 OpenAI 官方服务）
# 例如 DeepSeek: https://api.deepseek.com/v1
# 例如私有部署: http://localhost:11434/v1
HOTPLEX_BRAIN_ENDPOINT=

# --- 🧠 大脑高级配置 (仅在需要精调时修改) ---

# 请求超时时间（秒）
# HOTPLEX_BRAIN_TIMEOUT_S=10

# 大脑缓存大小（存储常用推理结果，提高响应速度）
# HOTPLEX_BRAIN_CACHE_SIZE=1000

# 失败重试设置
# HOTPLEX_BRAIN_MAX_RETRIES=3
# HOTPLEX_BRAIN_RETRY_MIN_WAIT_MS=100
# HOTPLEX_BRAIN_RETRY_MAX_WAIT_MS=5000

# 速率限制 (Rate Limiting)
# HOTPLEX_BRAIN_RATE_LIMIT_ENABLED=false
# HOTPLEX_BRAIN_RATE_LIMIT_RPS=10.0
# HOTPLEX_BRAIN_RATE_LIMIT_BURST=20

# 熔断器 (Circuit Breaker - 保护 API 免受级联故障影响)
# HOTPLEX_BRAIN_CIRCUIT_BREAKER_ENABLED=false
# HOTPLEX_BRAIN_CIRCUIT_BREAKER_MAX_FAILURES=5
# HOTPLEX_BRAIN_CIRCUIT_BREAKER_TIMEOUT=30s

# 成本控制与配额 (Budget)
# HOTPLEX_BRAIN_COST_TRACKING_ENABLED=true
# HOTPLEX_BRAIN_BUDGET_ENABLED=false
# HOTPLEX_BRAIN_BUDGET_LIMIT=10.0
# HOTPLEX_BRAIN_BUDGET_PERIOD=daily


# ------------------------------------------------------------------------------
# 5. ⚡ 运行性能与监控日志
# ------------------------------------------------------------------------------

# 执行超时：AI 进程处理单条指令的最大宽限时间。
# 默认值：30m (30分钟)
HOTPLEX_EXECUTION_TIMEOUT=30m

# 会话空闲超时：Bot 在无任何交互后自动释放后端进程的时间。
# 默认值：30m
HOTPLEX_IDLE_TIMEOUT=30m

# 日志级别：DEBUG, INFO, WARN, ERROR
# 开发调试建议设为 DEBUG，生产环境建议 INFO。
HOTPLEX_LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# 6. 📁 工作空间与身份 (Workspaces & Identity)
# ------------------------------------------------------------------------------

# 默认项目根目录：Bot 访问和操作文件的“保险箱”
# 在 Docker 模式下，此目录将挂载到容器内的 /home/hotplex/projects
HOTPLEX_PROJECTS_DIR=${HOME}/.slack/BOT_USER_ID

# Git 配置文件映射：让 Bot 拥有自己的 Git 签名和配置
# 映射到容器：/home/hotplex/.gitconfig
HOTPLEX_GITCONFIG=${HOME}/.gitconfig-bot

# GitHub 个人访问令牌 (PAT)
# 用于 Bot 在容器内推代码、提交 PR、操作 Issue 等。
# 获取地址：https://github.com/settings/tokens (classic) -> 勾选 'repo' 权限。
GITHUB_TOKEN=ghp_在此处填写你的GitHub令牌

# ------------------------------------------------------------------------------
# 7. 🛡️ 安全响应与告警 (Security & Alerts)
# ------------------------------------------------------------------------------

# 钉钉机器人告警（用于接收系统级拦截通知或关键崩溃报告）
HOTPLEX_DINGTALK_ENABLED=false
HOTPLEX_DINGTALK_WEBHOOK_URL=
HOTPLEX_DINGTALK_SECRET=
# 过滤事件类型（以逗号分隔）
HOTPLEX_DINGTALK_FILTER_EVENTS=danger.blocked,session.error

# ------------------------------------------------------------------------------
# 8. ⚙️ 系统路径与高级目录
# ------------------------------------------------------------------------------
# 查找优先级：环境变量 > ~/.hotplex/configs > ./chatapps/configs

# HotPlex 用户主目录（存储持久化状态、日志等）
# 默认值：~/.hotplex
# HOTPLEX_CONFIG_DIR=/path/to/custom/dir

# 独立的应用配置文件存储目录
# 默认值：${HOTPLEX_CONFIG_DIR}/configs
# HOTPLEX_CHATAPPS_CONFIG_DIR=/path/to/configs


