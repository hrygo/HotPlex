# HotPlex Webchat Configuration
# All vars use HOTPLEX_WEBCHAT_ prefix.
# next.config.mjs auto-forwards them to the client bundle.
# See lib/config.ts for defaults and documentation.

# -- Gateway connection (required) --
HOTPLEX_WEBCHAT_WS_URL=ws://localhost:8888/ws
HOTPLEX_WEBCHAT_API_KEY=dev

# -- Worker defaults --
# Worker type for new sessions: claude_code | open_code_server
HOTPLEX_WEBCHAT_WORKER_TYPE=claude_code

# -- Per-session init config (optional) --
# Working directory for the worker. Empty = gateway default.
HOTPLEX_WEBCHAT_WORK_DIR=
# Comma-separated allowed tools. Empty = no restriction.
# Example: Read,Write,Bash,Glob,Grep
HOTPLEX_WEBCHAT_ALLOWED_TOOLS=
